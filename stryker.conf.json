{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing focado na logica pura do front (src/lib). Cada feature adiciona seus modulos aqui.",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "mutate": ["src/lib/**/*.ts", "!src/lib/**/*.{test,spec}.ts"],
  "thresholds": {
    "high": 90,
    "low": 75,
    "break": 60
  }
}
